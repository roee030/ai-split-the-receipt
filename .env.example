# ─── AI Providers ──────────────────────────────────────────────────────────────
# Required: Gemini API key (Google AI Studio → https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Anthropic / Claude (enables Claude fallback when Gemini quota runs out)
# Dev:  Leave unset — Vite proxies /api/anthropic → api.anthropic.com automatically
# Prod: Set to your Cloudflare Worker / Firebase Function proxy URL
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
VITE_ANTHROPIC_PROXY_URL=https://your-proxy.workers.dev   # prod only

# ─── Provider Routing (optional — defaults shown) ─────────────────────────────
# Controls which model runs each pipeline pass. Restart dev server after changes.
# Options: gemini-2.0-flash | gemini-2.5-flash | gemini-1.5-flash | gemini-2.0-flash-lite | claude-sonnet-4-5
VITE_PASS1_PROVIDER=gemini-2.0-flash
VITE_PASS2_PROVIDER=gemini-2.0-flash
VITE_MAGIC_PROVIDER=gemini-2.0-flash

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Analytics (optional) ──────────────────────────────────────────────────────
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_SENTRY_DSN=your_sentry_dsn_here
